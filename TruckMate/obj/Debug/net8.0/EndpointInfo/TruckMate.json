{
  "openapi": "3.0.1",
  "info": {
    "title": "TruckMate",
    "version": "1.0"
  },
  "paths": {
    "/register": {
      "post": {
        "tags": [
          "Register"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/WeatherForecast": {
      "get": {
        "tags": [
          "WeatherForecast"
        ],
        "operationId": "GetWeatherForecast",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DriverSignUpDto": {
        "required": [
          "capacity",
          "confirmPassword",
          "email",
          "fullName",
          "licenseNumber",
          "licenseType",
          "nationalId",
          "otpVerificationCode",
          "password",
          "phone",
          "plateNumber",
          "truckType"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "phone": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string",
            "format": "tel"
          },
          "email": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string",
            "format": "email"
          },
          "nationalId": {
            "minLength": 1,
            "pattern": "^\\d{14}$",
            "type": "string"
          },
          "licenseNumber": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "licenseType": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "licenseImageBase64": {
            "type": "string",
            "nullable": true
          },
          "plateNumber": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "truckType": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "capacity": {
            "type": "number",
            "format": "double"
          },
          "password": {
            "maxLength": 100,
            "minLength": 8,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d).+$",
            "type": "string"
          },
          "confirmPassword": {
            "minLength": 1,
            "type": "string"
          },
          "otpVerificationCode": {
            "minLength": 1,
            "pattern": "^\\d{6}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "role": {
            "$ref": "#/components/schemas/UserRole"
          },
          "driver": {
            "$ref": "#/components/schemas/DriverSignUpDto"
          },
          "trader": {
            "$ref": "#/components/schemas/TraderSignUpDto"
          }
        },
        "additionalProperties": false
      },
      "TraderSignUpDto": {
        "required": [
          "businessName",
          "confirmPassword",
          "email",
          "fullName",
          "nationalId",
          "otpVerificationCode",
          "password",
          "phone"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "phone": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string",
            "format": "tel"
          },
          "email": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string",
            "format": "email"
          },
          "nationalId": {
            "minLength": 1,
            "pattern": "^\\d{14}$",
            "type": "string"
          },
          "businessName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "address": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "password": {
            "maxLength": 100,
            "minLength": 8,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d).+$",
            "type": "string"
          },
          "confirmPassword": {
            "minLength": 1,
            "type": "string"
          },
          "otpVerificationCode": {
            "minLength": 1,
            "pattern": "^\\d{6}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UserRole": {
        "enum": [
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}